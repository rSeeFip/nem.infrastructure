  "panels": [
    {
      "description": "Tempo trace search is live in this environment, but Prometheus traces_service_graph_* and traces_spanmetrics_* series are empty, so this dashboard falls back to Tempo-first exploration.",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "content": "### Tempo-first trace view\nLive QA in this runner must use Tempo search results because Prometheus trace-derived metrics are empty.\n\n- Default service filter now matches live traces: `unknown_service:dotnet`\n- Use **Trace Search** for broad lookup\n- Use **Traces Above Min Duration** and **Error Traces** for focused drilldown",
        "mode": "markdown"
      },
      "title": "Live Stack Trace Mode",
      "type": "text"
    },
    {
      "datasource": {
        "uid": "tempo",
        "type": "tempo"
      },
      "description": "Tempo trace search with live service defaults aligned to the current runner. Trace drilldowns to logs and metrics come from Tempo datasource provisioning.",
      "fieldConfig": {
        "defaults": {
          "links": []
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 2,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "uid": "tempo",
            "type": "tempo"
          },
          "limit": 20,
          "query": "{ resource.service.name =~ \"$service\" && name =~ \".*$operation.*\" }",
          "queryType": "search",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Trace Search",
      "type": "table"
    },
    {
      "description": "Prometheus trace-derived metrics are unavailable in this live stack, so the duration histogram is intentionally replaced with Tempo-focused guidance.",
