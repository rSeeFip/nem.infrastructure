      "id": 7,
      "options": {
        "query": {
          "queryType": "traceql",
          "query": "{.stigmergy_trace_id=\"$stigmergy_trace_id\"}"
        }
      },
      "targets": [
        {
          "datasource": {
            "uid": "tempo",
            "type": "tempo"
          },
          "queryType": "traceql",
          "query": "{.stigmergy_trace_id=\"$stigmergy_trace_id\"}",
