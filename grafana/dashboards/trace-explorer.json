      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "uid": "tempo",
            "type": "tempo"
          },
          "limit": 20,
          "query": "{ resource.service.name =~ \"$service\" && name =~ \".*$operation.*\" && duration > $minDuration }",
          "queryType": "search",
          "refId": "A",
          "tableType": "traces"
        }
