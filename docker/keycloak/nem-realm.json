{
  "realm": "nem",
  "enabled": true,
  "displayName": "nem local realm",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "bruteForceProtected": false,
  "clients": [
    {
      "clientId": "nem-mcp",
      "name": "nem MCP",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://localhost:5000/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://localhost:5000"
      ]
    },
    {
      "clientId": "nem-mimir",
      "name": "nem Mimir",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5223/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5223"
      ]
    }
  ],
  "users": [
    {
      "username": "dev-admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Dev",
      "lastName": "Admin",
      "email": "dev-admin@nem.local",
      "credentials": [
        {
          "type": "password",
          "value": "dev-password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "offline_access",
        "uma_authorization"
      ]
    }
  ]
