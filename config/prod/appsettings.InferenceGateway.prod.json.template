{
  "LiteLlm": {
    "BaseUrl": "${LITELLM_API_URL}",
    "ApiKey": "${LITELLM_API_KEY}",
    "TimeoutSeconds": 120
  },
  "llm": {
    "providers": {
      "lmstudio": {
        "endpoint": "${LMSTUDIO_API_URL}",
        "enabled": true
      }
    }
  },
  "InferenceRouting": {
    "Providers": {
      "litellm": {
        "Id": "71b6cb01-8b26-4f69-92f6-10d3cb57cb8f",
        "ModelName": "qwen-2.5-72b",
        "IsLocal": false,
        "Enabled": true,
        "Capabilities": ["TextGeneration", "CodeGeneration"],
        "MaxTokens": 8192,
        "CostPerToken": 0.00001
      },
      "lmstudio": {
        "Id": "3e7a1f2b-9c4d-4e8a-b5f6-2d1c0e9a7b3f",
        "ModelName": "google/gemma-4-26b-a4b-qat",
        "IsLocal": true,
        "Enabled": true,
        "Capabilities": ["TextGeneration"],
        "MaxTokens": 8192,
        "CostPerToken": 0.0
      }
    },
    "TierRouting": {
      "Router": { "Primary": "litellm", "Secondary": "lmstudio", "Local": "lmstudio" },
      "Validation": { "Primary": "litellm", "Secondary": "lmstudio", "Local": "lmstudio" },
      "Processing": { "Primary": "litellm", "Secondary": "lmstudio", "Local": "lmstudio" },
      "Analysis": { "Primary": "litellm", "Secondary": "lmstudio", "Local": "lmstudio" },
      "Escalation": { "Primary": "litellm", "Secondary": "lmstudio", "Local": "lmstudio" }
    },
    "PerInvocationCeiling": 0.1,
    "ProviderFailureThreshold": 5,
    "ProviderCooldownSeconds": 60,
    "DefaultBudget": {
      "DailyLimit": 50.0,
      "MonthlyLimit": 1000.0,
      "AlertThresholds": [0.5, 0.8, 0.95]
    },
    "DeploymentMode": {
      "Mode": "Cloud",
      "LocalProviderName": "lmstudio"
    }
  },
  "Routing": {
    "Semantic": {
      "SimilarityThreshold": 0.75,
      "PolicyName": "nem.mcp.controlplane"
    }
  },
  "Keycloak": {
    "Authority": "${KEYCLOAK_AUTHORITY}",
    "Audience": "nem-mcp",
    "RequireHttpsMetadata": true
  },
  "ConnectionStrings": {
    "InferenceGateway": "${INFERENCE_GATEWAY_DB_CONNECTION_STRING}"
  },
  "InferenceGateway": {
    "DeploymentMode": {
      "Mode": "Cloud",
      "SensitiveDataPatterns": ["\\b\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}[\\s-]?\\d{4}\\b", "\\b[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}\\b"],
      "StrictLocalEnforcement": true,
      "LocalProviderName": "lmstudio"
    }
  }
}
