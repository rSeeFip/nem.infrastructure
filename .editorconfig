root = true

[*]
charset = utf-8
indent_style = tab
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{json,jsonc}]
indent_style = space
indent_size = 2

[*.{cs,csx}]
indent_style = tab
indent_size = 4

[*.{ts,tsx,js,jsx}]
indent_style = tab
indent_size = 4

[*.{html,css,scss}]
indent_style = tab
indent_size = 4

[*.xml]
indent_style = tab
indent_size = 4

[*.{csproj,props,targets}]
indent_style = space
indent_size = 2
